# IntelliPark Environment Variables
# Copy this file to .env and set your own values
# NEVER commit the .env file to version control

# Database password (required for Docker)
DB_PASSWORD=change_this_to_secure_password

# JWT Secret Key (required) - generate a long random string
# Example: openssl rand -hex 32
SECRET_KEY=generate_a_random_secret_key_here

# Flask environment (development/production)
FLASK_ENV=development

# Default admin user (optional - defaults shown)
ADMIN_EMAIL=admin@intellipark.com
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=Admin
