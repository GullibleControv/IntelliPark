# IntelliPark Environment Configuration
# Copy this file to .env and update the values

# Security - REQUIRED: Generate a secure random key
# Example: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
JWT_EXPIRATION_HOURS=24

# Database
# SQLite (development)
DATABASE_URL=sqlite:///intellipark.db
# PostgreSQL (production)
# DATABASE_URL=postgresql://user:password@localhost:5432/intellipark

# CORS - Comma separated list of allowed origins
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# App settings
DEBUG=True

# Detection settings
YOLO_MODEL_PATH=detection/models/yolo11s.pt
DETECTION_CONFIDENCE=0.5
